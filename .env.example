VITE_THREADS_APP_ID=YOUR_APP_ID_HERE
VITE_THREADS_REDIRECT_URI=http://localhost:5173/dashboard

# Server-only (Vercel Functions). Do NOT expose in Vite (no VITE_ prefix).
THREADS_APP_SECRET=YOUR_APP_SECRET_HERE

# Supabase
# Public (optional, only needed if the browser reads Supabase directly)
VITE_SUPABASE_URL=https://xxx.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Server-only (recommended for cron / internal APIs)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Vercel Cron auth
CRON_SECRET=YOUR_RANDOM_SECRET

# App session (server-only). Used to sign httpOnly cookie for dashboard state.
SESSION_SECRET=YOUR_RANDOM_SESSION_SECRET
